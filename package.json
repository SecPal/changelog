{
  "name": "secpal-changelog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && node scripts/generate-feed.mjs && node scripts/generate-csp.mjs",
    "check": "tsc --noEmit",
    "csp:check": "node scripts/generate-csp.mjs --check",
    "csp:update": "node scripts/generate-csp.mjs --write",
    "lint": "eslint . --max-warnings=0",
    "preflight": "bash scripts/preflight.sh",
    "format": "prettier --write --cache '**/*.{md,yml,yaml,json,ts,tsx,js,jsx}'",
    "format:check": "prettier --check '**/*.{md,yml,yaml,json,ts,tsx,js,jsx}'"
  },
  "browserslist": "defaults, not ie <= 11",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "feed": "^5.2.1",
    "mdast-util-to-string": "^4.0.0",
    "mdx-annotations": "^0.1.4",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recma-import-images": "^0.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype-wrap": "^0.0.5",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "0.34.5"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
